{
  "name": "edhack",
  "private": true,
  "version": "0.2.0",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "concurrently --names mastra,web --prefix-colors magenta,cyan \"pnpm -C packages/mastra dev\" \"pnpm -C packages/web dev\"",
    "dev:mastra": "pnpm -C packages/mastra dev",
    "dev:web": "pnpm -C packages/web dev",
    "build": "pnpm -C packages/mastra build && pnpm -C packages/web build",
    "lint": "pnpm -C packages/web lint",
    "typecheck": "pnpm -C packages/mastra exec tsc --noEmit && pnpm -C packages/web exec tsc --noEmit",
    "generate": "pnpm -C packages/mastra generate",
    "demo:reject": "pnpm -C packages/mastra demo:reject",
    "test:sandbox": "pnpm -C packages/mastra test:sandbox",
    "e2e": "pnpm -C packages/web e2e",
    "e2e:docente": "pnpm -C packages/web e2e -- --grep docente",
    "e2e:estudiante": "pnpm -C packages/web e2e -- --grep estudiante",
    "e2e:integracion": "pnpm -C packages/web e2e -- --grep integraci"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  }
}
