{
  "name": "@edhack/mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/server.ts",
  "bin": {
    "classos-mcp-stdio": "./src/transports/stdio.ts"
  },
  "scripts": {
    "dev": "tsx watch src/transports/stdio.ts",
    "start": "tsx src/transports/http.ts",
    "start:stdio": "tsx src/transports/stdio.ts",
    "start:http": "tsx src/transports/http.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@edhack/contracts": "workspace:*",
    "@mastra/core": "^1.28.0",
    "@mastra/mcp": "^1.5.2",
    "@supabase/supabase-js": "^2.104.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
